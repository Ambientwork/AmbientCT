# =============================================================================
# AmbientCT — Environment Configuration
# =============================================================================
# Copy this to .env and customize before first run:
#   cp .env.example .env
#
# IMPORTANT: Generate a secure password before deploying!
#   openssl rand -base64 16
# =============================================================================

# === Orthanc PACS Server =====================================================

# HTTP API port (browser access to Orthanc Explorer)
ORTHANC_HTTP_PORT=8042

# DICOM DIMSE port (for receiving images from dental equipment via C-STORE)
# Configure your CBCT/OPG scanner to send to this port
ORTHANC_DICOM_PORT=4242

# Orthanc admin credentials (used for API access and OHIF authentication)
# REQUIRED: Change the password before first use!
ORTHANC_USER=admin
ORTHANC_PASSWORD=changeme-on-first-run

# DICOM Application Entity Title (identifies this PACS on the network)
# Must match the AE Title configured on your dental imaging equipment
DICOM_AE_TITLE=DENTALPACS

# Human-readable name shown in the Orthanc web interface
ORTHANC_INSTANCE_NAME=AmbientCT

# Allow overwriting existing DICOM instances (true = update on re-import)
ORTHANC_OVERWRITE_INSTANCES=true

# Time (seconds) before a study is considered stable (no new images expected)
ORTHANC_STABLE_AGE=60

# Maximum results returned by DICOM queries (increase for large archives)
ORTHANC_LIMIT_FIND_RESULTS=100
ORTHANC_LIMIT_FIND_INSTANCES=100

# Number of HTTP worker threads (increase for concurrent users)
ORTHANC_HTTP_THREADS=10

# === OHIF Viewer ==============================================================

# Port for the OHIF web viewer (open http://localhost:3000 in your browser)
VIEWER_PORT=3000

# OHIF Docker image version (pin to avoid breaking changes)
OHIF_VERSION=v3.9.2

# === Resource Limits ==========================================================
# Adjust based on your server hardware. Rendering happens in the browser (GPU),
# so server resources are mainly for DICOM storage and API serving.

# Orthanc: handles DICOM parsing, indexing, and DICOMweb API
ORTHANC_MEM_LIMIT=512m
ORTHANC_CPUS=1.0

# Viewer: serves static files only (React app + Cornerstone3D)
VIEWER_MEM_LIMIT=256m
VIEWER_CPUS=0.5

# === Logging ==================================================================
# Docker JSON log driver settings — prevents unbounded log growth

# Maximum size per log file before rotation
LOG_MAX_SIZE=10m

# Number of rotated log files to keep
LOG_MAX_FILE=3

# === CORS (Security) ==========================================================
# Comma-separated list of allowed origins for cross-origin requests.
# Leave empty or omit to allow same-origin only (recommended for LAN).
# Example for production with Nginx: CORS_ALLOWED_ORIGINS=https://pacs.praxis.local
CORS_ALLOWED_ORIGINS=

# === Nginx (production only) ==================================================
# Uncomment and configure when enabling the Nginx reverse proxy service
# in docker-compose.yml for HTTPS/SSL termination.
# IMPORTANT: Never serve patient data over plain HTTP in production!

# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
# SSL_CERT_PATH=./config/nginx/ssl/cert.pem
# SSL_KEY_PATH=./config/nginx/ssl/key.pem
