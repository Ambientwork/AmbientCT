# dental-pacs-box Environment Configuration
# Copy this to .env and customize before first run:
#   cp .env.example .env

# === Orthanc PACS Server ===
ORTHANC_HTTP_PORT=8042
ORTHANC_DICOM_PORT=4242
ORTHANC_USER=admin
ORTHANC_PASSWORD=changeme-on-first-run
DICOM_AE_TITLE=DENTALPACS

# === OHIF Viewer ===
VIEWER_PORT=3000

# === Nginx (production only) ===
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
# SSL_CERT_PATH=./config/nginx/ssl/cert.pem
# SSL_KEY_PATH=./config/nginx/ssl/key.pem
